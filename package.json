{
  "name": "fb-group-aggregator",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:extension": "pnpm --filter extension dev",
    "dev:server": "pnpm --filter server dev",
    "dev:webapp": "pnpm --filter webapp dev",
    "dev:all": "pnpm run --parallel dev:extension dev:server dev:webapp",
    "test": "pnpm run --recursive test",
    "build:all": "pnpm run --recursive build",
    "prepare": "husky",
    "lint": "eslint . --fix",
    "format": "prettier --write --log-level=warn .",
    "format:check": "prettier --check --log-level=warn .",
    "check": "pnpm -r check",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1"
  },
  "lint-staged": {
    "extension/**/*": "pnpm --filter extension lint-staged"
  }
}
